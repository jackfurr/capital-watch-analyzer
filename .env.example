# Scraper API configuration
SCRAPER_API_URL=http://localhost:8000
SCRAPER_API_KEY=your-api-key-here

# Report generation
REPORTS_DIR=./reports
WEEKLY_REPORT_DAY=3  # 0=Monday, 3=Wednesday

# Logging
LOG_LEVEL=INFO
LOG_JSON=false

# Email distribution via Brevo (optional)
# Brevo free tier: 300 emails/day
# Get API key at: https://app.brevo.com/settings/keys/api
# BREVO_API_KEY=
# EMAIL_FROM=reports@capitolwatch.dev
# EMAIL_TO=your-email@example.com

# Discord webhook (optional)
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Finnhub API (optional - for ticker lookup)
# Finnhub free tier: 60 calls/minute
# Get API key at: https://finnhub.io/register
# FINNHUB_API_KEY=
