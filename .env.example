# Scraper API configuration
SCRAPER_API_URL=http://localhost:8000
SCRAPER_API_KEY=your-api-key-here

# Report generation
REPORTS_DIR=./reports
WEEKLY_REPORT_DAY=3  # 0=Monday, 3=Wednesday

# Logging
LOG_LEVEL=INFO
LOG_JSON=false

# Email distribution (optional)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM=
# EMAIL_TO=

# Discord webhook (optional)
# DISCORD_WEBHOOK_URL=
